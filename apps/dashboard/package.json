{
  "name": "olly-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bash -lc 'set -o pipefail; mkdir -p logs && vite build 2>&1 | tee logs/build.log'",
    "dev": "bash -lc 'set -o pipefail; mkdir -p logs && vite dev 2>&1 | tee logs/dev.log'",
    "_note": "dashboard writes vite output directly; the root `bun run dev` script additionally routes structured lib/log.ts events into apps/dashboard/logs/dev.log via scripts/split-logs.ts"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.6",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.11.6",
    "@cloudflare/workers-types": "^4.20250805.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "alchemy": "^0.91.2",
    "typescript": "^5.7.2",
    "vite": "^7.1.9"
  }
}
